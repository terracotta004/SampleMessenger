{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "dotnet build MauiMessenger.Api",
            "type": "process",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/src/MauiMessenger.Api/MauiMessenger.Api.csproj"
            ],
            "problemMatcher": "$msCompile",
            "group": "build"
        },
        {
            "label": "dotnet build MauiMessenger.Client.Web",
            "type": "process",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/src/MauiMessenger.Client.Web/MauiMessenger.Client.Web.csproj"
            ],
            "problemMatcher": "$msCompile",
            "group": "build"
        },
        {
            "label": "maui: Build MauiMessenger.Client.Mobile",
            "type": "process",
            "command": "/Users/ben/.dotnet/dotnet",
            "args": [
                "build",
                "${workspaceFolder}/src/MauiMessenger.Client.Mobile/MauiMessenger.Client.Mobile.csproj",
                "-f",
                "net10.0-ios",
                "-p:RuntimeIdentifier=iossimulator-arm64"
            ],
            "problemMatcher": "$msCompile",
            "options": {
                "env": {
                    "DEVELOPER_DIR": "/Applications/Xcode-26.3.app/Contents/Developer"
                }
            },
            "group": "build"
        }
    ]
}
