{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "MauiMessenger.Api",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "dotnet build MauiMessenger.Api",
            "program": "${workspaceFolder}/src/MauiMessenger.Api/bin/Debug/net10.0/MauiMessenger.Api.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/MauiMessenger.Api",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://0.0.0.0:5010"
            }
        },
        {
            "name": "MauiMessenger.Client.Web",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "dotnet build MauiMessenger.Client.Web",
            "program": "${workspaceFolder}/src/MauiMessenger.Client.Web/bin/Debug/net10.0/MauiMessenger.Client.Web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/MauiMessenger.Client.Web",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:5125"
            }
        },
        {
            "name": "MauiMessenger.Client.Mobile",
            "type": "node-terminal",
            "request": "launch",
            "preLaunchTask": "maui: Clean MauiMessenger.Client.Mobile",
            "command": "DEVELOPER_DIR=/Applications/Xcode-26.3.app/Contents/Developer /Users/ben/.dotnet/dotnet build ${workspaceFolder}/src/MauiMessenger.Client.Mobile/MauiMessenger.Client.Mobile.csproj -f net10.0-ios -p:RuntimeIdentifier=iossimulator-arm64 -p:_DeviceName=:v2:udid=84479A6F-CFBC-470A-B03D-224B537F212F \"-t:Build;Run\"",
            "cwd": "${workspaceFolder}"
        }
    ],
    "compounds": [
        {
            "name": "MauiMessenger.Api + Web",
            "configurations": [
                "MauiMessenger.Api",
                "MauiMessenger.Client.Web"
            ]
        },
        {
            "name": "MauiMessenger.Api + Mobile",
            "configurations": [
                "MauiMessenger.Api",
                "MauiMessenger.Client.Mobile"
            ]
        },
        {
            "name": "MauiMessenger.Api + Web + Mobile",
            "configurations": [
                "MauiMessenger.Api",
                "MauiMessenger.Client.Web",
                "MauiMessenger.Client.Mobile"
            ]
        }
    ]
}
